<h1>New Diary Entry</h1>

<h1 class="text-3xl font-bold mb-6 text-gray-800">✍️ New Diary Entry</h1>

<%= form_with model: @diary_entry, local: true, class: "space-y-6 bg-white p-8 rounded-2xl shadow-lg max-w-lg" do |form| %>

  <% if @diary_entry.errors.any? %>
    <div class="bg-red-50 border border-red-300 text-red-700 px-4 py-3 rounded-lg">
      <h3 class="font-semibold mb-2">
        <%= pluralize(@diary_entry.errors.count, "error") %> prevented this entry from saving:
      </h3>
      <ul class="list-disc pl-5">
        <% @diary_entry.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :title, 
        class: "w-full px-4 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:outline-none" %>
  </div>

  <div>
    <%= form.label :content, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_area :content, 
        rows: 6, 
        class: "w-full px-4 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:outline-none" %>
  </div>

  <div>
    <%= form.submit "💾 Save Entry", 
        class: "bg-blue-600 text-white px-6 py-2 rounded-lg shadow hover:bg-blue-700 transition" %>
  </div>

<% end %>
